{
  "meta": {"schema_version": "1.0.0"},
  "runtime": {"mode": "live", "arm_live_trading": true},
  "exchange": {"name": "mock_spot", "credentials_env": "LIVE_EXCHANGE_CREDENTIALS"},
  "market": {"symbol": "BTC-USDT", "price_source": "exchange_best_bid_ask"},
  "strategy": {
    "grid_type": "static_neutral",
    "spacing_type": "geometric",
    "lower_price": "26000",
    "upper_price": "34000",
    "num_levels": 5,
    "anchor_price_mode": "midpoint",
    "total_quote_allocation": "1000",
    "per_level_sizing_mode": "equal_quote",
    "post_only": true,
    "time_in_force": "GTC"
  },
  "risk": {
    "max_inventory_base": "0.08",
    "max_drawdown_pct": "15",
    "max_daily_loss_quote": "400",
    "max_reject_streak": 3,
    "stale_market_data_seconds": 10,
    "stale_private_stream_seconds": 10,
    "max_reconciliation_mismatches": 2
  },
  "persistence": {"sqlite_path": "./grid_trader_live.db", "snapshot_interval_seconds": 20},
  "telemetry": {"log_level": "INFO"}
}
